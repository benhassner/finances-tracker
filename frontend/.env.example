# Frontend Environment Variables
# Copy this file to .env.local and configure for your environment

# Backend API URL (for production deployment)
# Default: http://127.0.0.1:8000 (local development)
# Production: https://your-backend-domain.com
VITE_API_URL=http://127.0.0.1:8000

# Example production setting:
# VITE_API_URL=https://finances-api.onrender.com
