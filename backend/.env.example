# Backend Environment Variables Configuration

# Database Configuration
# For Supabase PostgreSQL: Use the "Transaction Pool" connection string from Supabase Dashboard
# For standard PostgreSQL: postgresql://user:password@host:5432/dbname?sslmode=require
# For local SQLite: (leave empty or remove this line to use default)
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres?sslmode=require

# Server Configuration
# Host to bind to (0.0.0.0 for production, 127.0.0.1 for local)
HOST=0.0.0.0

# Port (Render/Vercel automatically sets PORT environment variable)
PORT=8000

# CORS Configuration
# Frontend URL for production deployment (must include https:// protocol)
# Leave empty to use localhost origins only (local development)
FRONTEND_URL=https://finances-tracker.vercel.app

# Optional: Logging level
# LOG_LEVEL=INFO

# Optional: Number of Uvicorn workers (leave empty for auto)
# WORKERS=4

# Example configurations:

# ╔════════════════════════════════════════════════════════════════╗
# ║ LOCAL DEVELOPMENT (no need to set, defaults work)              ║
# ╠════════════════════════════════════════════════════════════════╣
# ║ DATABASE_URL defaults to SQLite at ./data/db/finance.db        ║
# ║ HOST defaults to 127.0.0.1                                      ║
# ║ PORT defaults to 8000                                           ║
# ╚════════════════════════════════════════════════════════════════╝

# ╔════════════════════════════════════════════════════════════════╗
# ║ RENDER PRODUCTION DEPLOYMENT                                    ║
# ╠════════════════════════════════════════════════════════════════╣
# ║ DATABASE_URL=postgresql://user:pass@db.render.com:5432/db      ║
# ║ HOST=0.0.0.0                                                    ║
# ║ FRONTEND_URL=https://finances-frontend.vercel.app              ║
# ╚════════════════════════════════════════════════════════════════╝

# ╔════════════════════════════════════════════════════════════════╗
# ║ SUPABASE PRODUCTION DEPLOYMENT                                  ║
# ╠════════════════════════════════════════════════════════════════╣
# ║ DATABASE_URL=postgresql://postgres:password@db.supabase.co:    ║
# ║              5432/postgres?sslmode=require                      ║
# ║ HOST=0.0.0.0                                                    ║
# ║ FRONTEND_URL=https://finances-frontend.vercel.app              ║
# ╚════════════════════════════════════════════════════════════════╝

