# Database Configuration
# For PostgreSQL (production): postgresql://user:password@hostname:5432/dbname
# For SQLite (local development): sqlite:///./data/db/finance.db (or omit for default)
DATABASE_URL=

# Server Configuration
# Host to bind to (0.0.0.0 for production/Render, 127.0.0.1 for local development)
HOST=127.0.0.1

# Port to run on (Render sets PORT automatically; default 8000 for local)
PORT=8000

# CORS Configuration
# Frontend URL for production deployment (e.g., https://yourdomain.com)
# Leave empty to use default localhost origins only
FRONTEND_URL=

# Example production Render deployment:
# DATABASE_URL=postgresql://user:password@render-postgres-hostname:5432/finances
# HOST=0.0.0.0
# FRONTEND_URL=https://yourdomain.com
